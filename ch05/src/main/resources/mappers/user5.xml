<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 5.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ch05.dao.User5DAO">

    <!-- id 값은 DAO의 메서드명으로 맞추기 -->
    <select id="select" resultType="org.example.ch05.dto.User5DTO">
        SELECT * FROM User5 WHERE seq=#{seq};
    </select>

    <select id="selectAll" resultType="org.example.ch05.dto.User5DTO">
        SELECT * FROM User5;
    </select>

    <insert id="insert">
        INSERT INTO User5 SET
                            seq=#{seq},
                            name=#{name},
                            gender=#{gender},
                            age=#{age},
                            addr=#{addr};
    </insert>

    <update id="update">
        UPDATE User5 SET
                        name=#{name},
                        gender=#{gender},
                        age=#{age},
                        addr=#{addr}
                    WHERE
                        seq=#{seq};

    </update>

    <delete id="delete">
        DELETE FROM User5 WHERE seq=#{seq};
    </delete>

</mapper>