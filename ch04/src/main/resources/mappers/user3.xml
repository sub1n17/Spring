<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ch04.dao.User3DAO">

    <!-- id 값은 DAO의 메서드명으로 맞추기 -->
    <select id="select" resultType="org.example.ch04.dto.User3DTO">
        SELECT * FROM User3 WHERE userid=#{userid};
    </select>

    <select id="selectAll" resultType="org.example.ch04.dto.User3DTO">
        SELECT * FROM User3;
    </select>

    <insert id="insert">
        INSERT INTO User3 SET
                            userid=#{userid},
                            name=#{name},
                            birth=#{birth},
                            hp=#{hp},
                            addr=#{addr};
    </insert>

    <update id="update">
        UPDATE User3 SET
                        name=#{name},
                        birth=#{birth},
                        hp=#{hp},
                        addr=#{addr}
                    WHERE
                        userid=#{userid};

    </update>

    <delete id="delete">
        DELETE FROM User3 WHERE userid=#{userid};
    </delete>

</mapper>